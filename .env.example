# Wzór pliku .env - skopiuj do ".env" i uzupełnij wartości.
# Plik .env jest w .gitignore i NIE trafia do repozytorium.
# W produkcji (GitHub Actions) te same nazwy ustawia się jako GitHub Secrets.

# WYMAGANE: klucz Google (PageSpeed Insights API + Chrome UX Report API włączone w GCP)
GOOGLE_API_KEY=

# OPCJONALNE: wysyłka alertów (puste = tryb podglądu, nic nie wysyła)
RESEND_API_KEY=

# OPCJONALNE: odbiorcy alertów po przecinku (nigdy adresy @inpost.pl)
ALERT_RECIPIENTS=przemek@technedev.pl

# OPCJONALNE: adres dashboardu do linku w mailu (uzupełnić po włączeniu GitHub Pages)
DASHBOARD_URL=
